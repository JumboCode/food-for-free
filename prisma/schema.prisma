generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  role      Role     @default(PARTNER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  partnerId String?
  partner   Partner? @relation("UserPartner", fields: [partnerId], references: [id])
}

model Partner {
  id                  String   @id @default(cuid())
  organizationName    String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  clerkOrganizationId String   @unique
  users               User[]   @relation("UserPartner")
}

model InventoryTransaction {
  id                         Int              @id @default(autoincrement())
  date                       DateTime
  location                   String
  pantryProductName          String
  inventoryType              String
  amount                     Int
  productUnitsForDisplay     String?
  weightLbs                  Float?
  source                     String?
  destination                String?
  productInventoryRecordId18 String           @unique
}

model PackagesByItem {
  id                         Int                       @id @default(autoincrement())
  productPackageName         String?
  pantryProductName          String?
  lotSourceAccountName       String?
  lotFoodRescueProgram       String?
  distributionAmount         Int?
  pantryProductWeightLbs     Float?
  distributionCost           Float?
  productInventoryRecordId18 String?
  productPackageId18         String?

  @@index([productInventoryRecordId18])
  @@index([productPackageId18])
}

model ProductPackageDestination {
  id                 Int              @id @default(autoincrement())
  productPackageName String
  productPackageId18 String           @unique
  householdName      String
  householdId18      String
}

model AllInventoryTransactions {
  date                       DateTime
  location                   String
  pantryProductName          String
  inventoryType              String
  minimallyProcessedFood     Boolean?
  productType                String?
  amount                     Int
  productUnitsForDisplay     String?
  weightLbs                  Float?
  source                     String?
  destination                String?
  productInventoryRecordId18 String           @id
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @default(now())
}

model AllPackagesByItem {
  productPackageName         String?
  pantryProductName          String?
  lotSourceAccountName       String?
  lotFoodRescueProgram       String?
  distributionAmount         Int?
  pantryProductWeightLbs     Float?
  distributionCost           Float?
  productInventoryRecordId18 String           @id
  productPackageId18         String?
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @default(now())

  @@index([productInventoryRecordId18])
  @@index([productPackageId18])
}

model AllProductPackageDestinations {
  date               DateTime
  productPackageName String
  productPackageId18 String           @unique
  householdName      String
  destinationId      String
  pantryVisitId18    String           @id @default("##################")
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @default(now())

  @@index([destinationId])
}

enum Role {
  ADMIN
  PARTNER
}
