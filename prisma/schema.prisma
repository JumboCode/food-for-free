generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  name      String?
  email     String   @unique
  role      Role     @default(PARTNER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  partnerMemberships UserPartnerMembership[]
}

model Partner {
  householdId18       String   @id
  organizationName    String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  clerkOrganizationId String   @unique
  userMemberships     UserPartnerMembership[]
}

model UserPartnerMembership {
  userId            String
  partnerId         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  partner           Partner  @relation(fields: [partnerId], references: [householdId18], onDelete: Cascade)

  @@id([userId, partnerId])
  @@index([partnerId])
}

model AllInventoryTransactions {
  date                       DateTime
  location                   String
  pantryProductName          String
  inventoryType              String
  minimallyProcessedFood     Boolean?
  productType                String?
  amount                     Int
  productUnitsForDisplay     String?
  weightLbs                  Float?
  source                     String?
  destination                String?
  approvalStatus             String?
  productInventoryRecordId18 String           @id
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @default(now())
}

model AllPackagesByItem {
  productPackageName         String?
  pantryProductName          String?
  lotSourceAccountName       String?
  lotFoodRescueProgram       String?
  distributionAmount         Int?
  pantryProductWeightLbs     Float?
  distributionCost           Float?
  productInventoryRecordId18 String           @id
  productPackageId18         String?
  approvalStatus             String?
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @default(now())

  @@index([productInventoryRecordId18])
  @@index([productPackageId18])
}

model AllProductPackageDestinations {
  date                 DateTime
  productPackageName   String
  productPackageId18   String           @unique
  householdName        String
  householdId18        String
  pantryVisitId18      String           @id @default("##################")
  distributionStatus   String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @default(now())

  @@index([householdId18])
}

model JustEatsBoxes {
  productPackageName                   String
  productPackageRecordId               String
  numberPickedUp                       Int?
  numberDistributed                    Int?
  pounds                               Float?
  poundsDroppedOff                     Float?
  poundsLost                           Float?
  packageDistributionRecordId          String @id
  packageDistributionCreatedDate       DateTime
  packageDistributionLastModifiedDate  DateTime
  householdName                        String
  householdId                          String
  pantryVisitDateTime                  DateTime
  pantryVisitId                        String
  pantryVisitCreatedDate               DateTime
  pantryVisitLastModifiedDate          DateTime

  @@index([productPackageRecordId])
  @@index([packageDistributionRecordId])
  @@index([householdId])
  @@index([pantryVisitId])
}

enum Role {
  ADMIN
  PARTNER
}
